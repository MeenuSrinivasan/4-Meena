#LOADING THE PRE-TRAINED MODEL
from tensorflow.keras.models import load_model
from tensorflow.keras.layers import DepthwiseConv2D
def custom_depthwise_conv2d(*args, **kwargs):
if 'groups' in kwargs:
del kwargs['groups']
return DepthwiseConv2D(*args, **kwargs)
model = load_model(
"hand_gesture_model/keras_model.h5",
compile=False,
custom_objects={'DepthwiseConv2D': custom_depthwise_conv2d}
)
#LOADING CLASS LABELS
class_names = open(
"hand_gesture_model/labels.txt",
"r"
).readlines()
#PREPROCESSING INPUT IMAGE
from PIL import Image, ImageOps
import numpy as np
np.set_printoptions(suppress=True)
# Create an input array
data = np.ndarray(shape=(1, 224, 224, 3), dtype=np.float32)
# Load and preprocess image
image = Image.open("hand_gesture_images/thumbs_up.jpg").convert("RGB")
size = (224, 224)
image = ImageOps.fit(image, size, Image.Resampling.LANCZOS)
image_array = np.asarray(image)
normalized_image_array = (image_array.astype(np.float32) / 127.5) - 1
data[0] = normalized_image_array

#MAKING PREDICTIONS
prediction = model.predict(data)
index = np.argmax(prediction)
class_name = class_names[index]
confidence_score = prediction[0][index]
print("Predicted Gesture:", class_name[2:].strip())
print("Confidence Score:", confidence_score)
